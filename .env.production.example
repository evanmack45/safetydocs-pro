# SafetyDocs Pro - Production Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# Stripe (https://dashboard.stripe.com/apikeys)
# Use test keys (sk_test_...) for staging, live keys (sk_live_...) for production.
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret (https://dashboard.stripe.com/webhooks)
# Created when you register the webhook endpoint in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=whsec_...

# Anthropic Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...
