{
  "framework": "nextjs",
  "buildCommand": "next build --turbopack",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/generate-toolbox-talk/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/generate-jsa/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/generate-sssp/route.ts": {
      "maxDuration": 90
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
